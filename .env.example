# ── EIA API (inscription gratuite sur eia.gov) ────────────────────────────────
EIA_API_KEY=your_eia_api_key_here
EIA_BASE_URL=https://api.eia.gov/v2

# ── Frankfurter API (entièrement gratuit, pas de clé) ─────────────────────────
FRANKFURTER_BASE_URL=https://api.frankfurter.app

# ── World Bank API (entièrement gratuit, pas de clé) ─────────────────────────
WORLDBANK_BASE_URL=https://api.worldbank.org/v2

# ── Supabase (compte gratuit sur supabase.com) ───────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_DB_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Application ──────────────────────────────────────────────────────────────
# IMPORTANT : mettre APP_ENV=production et DEBUG=False sur Render.com
APP_ENV=development
APP_PORT=8050
API_PORT=8000
DEBUG=False
# En production : CORS_ORIGINS=https://lubricants-dash.onrender.com
CORS_ORIGINS=http://localhost:8050,http://localhost:8051

# ── Database locale (dev) ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./dev.db

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=lubricants_pricing

# ── Paths ─────────────────────────────────────────────────────────────────────
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
DATA_SYNTHETIC_PATH=./data/synthetic
REPORTS_PATH=./reports
